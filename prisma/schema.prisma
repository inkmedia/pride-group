generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProjectRecord {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  location  String
  category  String?
  status    String?
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
